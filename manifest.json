{
  "manifest_version": 3,
  "name": "Gemini Notebook (NotebookLM) Citation Hider",
  "version": "2.1",
  "description": "Hides citation numbers on Google's Gemini Notebook (formerly NotebookLM) for clean, distraction-free screenshots.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_icon": "icon.png",
    "default_title": "Toggle Citations"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://notebooklm.google.com/notebook/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
